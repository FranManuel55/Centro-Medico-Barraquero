---
import { getCollection } from 'astro:content';
import { getWhatsAppUrlContextual } from '../../data/siteConfig';

const faqs = await getCollection('faq');
faqs.sort((a, b) => a.data.order - b.data.order);
---

<section id="faq" class="section-padding">
  <div class="container-custom">
    <div class="text-center max-w-2xl mx-auto mb-14" data-reveal>
      <span class="eyebrow-accent mb-4">Preguntas frecuentes</span>
      <h2 class="section-title mb-4">Resolvé tus dudas</h2>
      <p class="section-lead">
        Encontrá respuestas a las preguntas más comunes sobre nuestros servicios y atención.
      </p>
    </div>

    <div class="max-w-3xl mx-auto space-y-3" data-reveal>
      {faqs.map((faq) => (
        <div
          class="bg-white border border-gray-100 rounded-xl overflow-hidden transition-all duration-200 hover:border-gray-200 hover:shadow-sm data-[open=true]:border-accent/30 data-[open=true]:shadow-md"
          data-faq-item
          data-open="false"
        >
          <button
            class="w-full px-5 py-4 flex items-center justify-between gap-4 text-left"
            aria-expanded="false"
            data-faq-toggle
          >
            <span class="text-base md:text-lg font-semibold text-text leading-snug">
              {faq.data.question}
            </span>
            <span
              class="shrink-0 w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center transition-all duration-200 group-data-[open=true]:bg-accent"
              data-faq-icon-wrap
            >
              <svg
                class="w-4 h-4 text-text-secondary transition-transform duration-300"
                data-faq-icon
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
              </svg>
            </span>
          </button>
          <div class="max-h-0 overflow-hidden transition-all duration-300" data-faq-content>
            <div class="px-5 pb-5 pt-0 text-text-secondary leading-relaxed border-t border-gray-100">
              <div class="pt-4">{faq.body}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center max-w-xl mx-auto" data-reveal>
      <p class="text-text-secondary mb-4">¿No encontraste lo que buscabas?</p>
      <a
        href={getWhatsAppUrlContextual('Hola! Tengo una consulta sobre Centro Médico Barraquero.')}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-secondary"
      >
        <svg class="w-4 h-4 mr-2" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Consultanos por WhatsApp
      </a>
    </div>
  </div>
</section>

<script>
  type FaqItem = {
    item: HTMLElement;
    toggle: HTMLButtonElement;
    content: HTMLElement;
    icon: HTMLElement;
    iconWrap: HTMLElement;
  };

  const items: FaqItem[] = Array.from(
    document.querySelectorAll('[data-faq-item]')
  ).map((el) => {
    const item = el as HTMLElement;
    return {
      item,
      toggle: item.querySelector('[data-faq-toggle]') as HTMLButtonElement,
      content: item.querySelector('[data-faq-content]') as HTMLElement,
      icon: item.querySelector('[data-faq-icon]') as HTMLElement,
      iconWrap: item.querySelector('[data-faq-icon-wrap]') as HTMLElement,
    };
  });

  const setOpen = (entry: FaqItem, open: boolean) => {
    entry.item.dataset.open = String(open);
    entry.toggle.setAttribute('aria-expanded', String(open));
    entry.content.style.maxHeight = open ? entry.content.scrollHeight + 'px' : '0';
    entry.icon.style.transform = open ? 'rotate(180deg)' : 'rotate(0deg)';
    entry.icon.classList.toggle('text-white', open);
    entry.icon.classList.toggle('text-text-secondary', !open);
    entry.iconWrap.classList.toggle('bg-accent', open);
    entry.iconWrap.classList.toggle('bg-gray-100', !open);
  };

  items.forEach((entry) => {
    entry.toggle?.addEventListener('click', () => {
      const willOpen = entry.item.dataset.open !== 'true';
      items.forEach((other) => {
        if (other !== entry) setOpen(other, false);
      });
      setOpen(entry, willOpen);
    });
  });
</script>
