---
const benefits = [
  {
    icon: 'users',
    title: 'Equipo profesional',
    description: 'Kinesiólogos especializados con amplia experiencia en rehabilitación y tratamiento de lesiones.',
  },
  {
    icon: 'heart',
    title: 'Atención personalizada',
    description: 'Cada paciente recibe un plan de tratamiento adaptado a sus necesidades específicas.',
  },
  {
    icon: 'map-pin',
    title: 'Ubicación accesible',
    description: 'Instalaciones cómodas y de fácil acceso en una zona estratégica de la ciudad.',
  },
  {
    icon: 'award',
    title: 'Calidad garantizada',
    description: 'Comprometidos con los más altos estándares de atención y resultados efectivos.',
  },
];
---

<section id="beneficios" class="section-padding bg-gray-50/60 relative overflow-hidden">
  <div
    class="absolute -top-24 -right-24 w-72 h-72 bg-secondary/10 rounded-full blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>
  <div
    class="absolute -bottom-24 -left-24 w-72 h-72 bg-accent/10 rounded-full blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-custom relative">
    <div class="text-center max-w-2xl mx-auto mb-14" data-reveal>
      <span class="eyebrow-secondary mb-4">Nuestra propuesta de valor</span>
      <h2 class="section-title mb-4">¿Por qué elegirnos?</h2>
      <p class="section-lead">
        En <span class="text-text font-semibold">Centro Médico Barraquero</span> nos esforzamos por
        brindarte la mejor atención en kinesiología y rehabilitación física.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
      {benefits.map((benefit, index) => (
        <article
          class="benefit-card group relative bg-white rounded-2xl p-6 lg:p-7 border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-gray-200 transition-all duration-300 overflow-hidden"
          data-reveal
        >
          <span
            class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-secondary to-accent scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-300"
            aria-hidden="true"
          ></span>

          <span
            class="absolute top-5 right-5 text-xs font-bold text-gray-300 group-hover:text-secondary/60 transition-colors duration-300"
            aria-hidden="true"
          >
            {String(index + 1).padStart(2, '0')}
          </span>

          <div
            class="w-14 h-14 rounded-xl bg-gradient-to-br from-secondary/15 to-secondary/5 flex items-center justify-center mb-5 group-hover:from-secondary group-hover:to-secondary/80 transition-all duration-300"
          >
            {benefit.icon === 'users' && (
              <svg
                class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
              </svg>
            )}
            {benefit.icon === 'heart' && (
              <svg
                class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
              </svg>
            )}
            {benefit.icon === 'map-pin' && (
              <svg
                class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
              </svg>
            )}
            {benefit.icon === 'award' && (
              <svg
                class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
              </svg>
            )}
          </div>

          <h3 class="text-lg lg:text-xl font-serif font-semibold text-text mb-2 leading-tight">
            {benefit.title}
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed">{benefit.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
