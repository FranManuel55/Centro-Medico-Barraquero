---
import { getCollection } from 'astro:content';
import { getWhatsAppUrlContextual } from '../../data/siteConfig';

const services = await getCollection('services');
services.sort((a, b) => a.data.order - b.data.order);
---

<section id="servicios" class="section-padding bg-gray-50/60 relative overflow-hidden">
  <div
    class="absolute top-0 right-0 w-80 h-80 bg-accent/5 rounded-full blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-custom relative">
    <div class="text-center max-w-2xl mx-auto mb-14" data-reveal>
      <span class="eyebrow-secondary mb-4">Nuestros servicios</span>
      <h2 class="section-title mb-4">Atención especializada para tu recuperación</h2>
      <p class="section-lead">
        Una amplia gama de tratamientos de kinesiología y rehabilitación física, diseñados para
        acompañarte en cada etapa.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {services.map((service) => (
        <article
          class="group relative bg-white rounded-2xl p-6 lg:p-7 border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-gray-200 transition-all duration-300 overflow-hidden"
          data-reveal
        >
          <span
            class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-secondary to-accent scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-300"
            aria-hidden="true"
          ></span>

          <div
            class="w-14 h-14 rounded-xl bg-gradient-to-br from-secondary/15 to-secondary/5 flex items-center justify-center mb-5 group-hover:from-secondary group-hover:to-secondary/80 transition-all duration-300"
          >
            {service.data.icon === 'activity' && (
              <svg class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
              </svg>
            )}
            {service.data.icon === 'user-check' && (
              <svg class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
              </svg>
            )}
            {service.data.icon === 'hand' && (
              <svg class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 14.25v2.25m3-4.5v4.5m12-7.125v1.875m0 4.5H18m-18-4.875h6.75m6.75 0v3c0 .621-.504 1.125-1.125 1.125h-3.75m-5.625 0h1.125M4.875 0H3m15 3.75h.75M4.875 3.75h.75m-1.5-4.5h.75m-1.5-4.5h.75"/>
              </svg>
            )}
            {service.data.icon === 'align-center' && (
              <svg class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 6.75V12m0 0v5.25m0 5.25H3m13.5-5.25H21m-1.5 0H15M3 6.75h18M3 12h18m0 5.25H3"/>
              </svg>
            )}
            {service.data.icon === 'wind' && (
              <svg class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z"/>
              </svg>
            )}
            {service.data.icon === 'thermometer' && (
              <svg class="w-7 h-7 text-secondary group-hover:text-white transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
              </svg>
            )}
          </div>

          <h3 class="text-lg lg:text-xl font-serif font-semibold text-text mb-2 leading-tight">
            {service.data.title}
          </h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-5">
            {service.data.description}
          </p>

          <a
            href={getWhatsAppUrlContextual(`Hola! Me interesa el servicio de ${service.data.title}.`)}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center text-sm font-semibold text-accent hover:text-accent-dark transition-colors group/link"
          >
            Consultá más información
            <svg
              class="w-4 h-4 ml-1 transition-transform duration-200 group-hover/link:translate-x-1"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
