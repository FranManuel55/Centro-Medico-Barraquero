---
import { getCollection } from 'astro:content';
import { siteConfig } from '../../data/siteConfig';

const reviews = await getCollection('reviews');
reviews.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const avatarPalette = [
  'from-secondary to-secondary/70',
  'from-accent to-accent-dark',
  'from-yellow-400 to-yellow-500',
  'from-pink-400 to-rose-500',
  'from-purple-400 to-indigo-500',
  'from-emerald-400 to-teal-500',
];
---

<section id="resenas" class="section-padding bg-gray-50/60 relative overflow-hidden">
  <div
    class="absolute -top-20 left-1/4 w-72 h-72 bg-accent/5 rounded-full blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-custom relative">
    <div class="text-center max-w-2xl mx-auto mb-14" data-reveal>
      <span class="eyebrow-secondary mb-4">Reseñas de Google</span>
      <h2 class="section-title mb-4">Lo que dicen nuestros pacientes</h2>

      <div class="flex items-center justify-center gap-3 mt-6">
        <div class="flex items-center">
          {[1, 2, 3, 4, 5].map((star) => (
            <svg
              class={`w-6 h-6 ${star <= Math.round(siteConfig.rating.average) ? 'text-yellow-400' : 'text-gray-300'}`}
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          ))}
        </div>
        <span class="text-xl font-serif font-semibold text-text">{siteConfig.rating.average}</span>
        <span class="text-text-secondary">({siteConfig.rating.count} reseñas)</span>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {reviews.slice(0, 6).map((review, index) => (
        <article
          class="relative bg-white rounded-2xl p-6 lg:p-7 border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
          data-reveal
        >
          <svg
            class="absolute top-5 right-5 w-10 h-10 text-secondary/15"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
          </svg>

          <div class="flex items-center gap-1 mb-4">
            {[1, 2, 3, 4, 5].map((star) => (
              <svg
                class={`w-4 h-4 ${star <= review.data.rating ? 'text-yellow-400' : 'text-gray-300'}`}
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>

          <p class="text-text text-sm leading-relaxed mb-5">"{review.data.text}"</p>

          <div class="flex items-center justify-between pt-4 border-t border-gray-100">
            <div class="flex items-center gap-3">
              <div class={`w-10 h-10 rounded-full bg-gradient-to-br ${avatarPalette[index % avatarPalette.length]} flex items-center justify-center shadow-sm`}>
                <span class="text-sm font-bold text-white">{review.data.name.charAt(0).toUpperCase()}</span>
              </div>
              <div>
                <p class="font-semibold text-text text-sm leading-tight">{review.data.name}</p>
                <p class="text-xs text-text-secondary mt-0.5">{review.data.date}</p>
              </div>
            </div>
            <svg class="w-5 h-5 text-gray-300" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 text-center" data-reveal>
      <a
        href="https://www.google.com/maps/place/Centro+M%C3%A9dico+Barraquero/@-32.9002722,-68.841877,16z/data=!4m10!1m2!2m1!1scentro+medico+barraquero!3m6!1s0x967e09145cd5c2e1:0x717c3fccb8572229!8m2!3d-32.8992812!4d-68.8390081!15sChhjZW50cm8gbWVkaWNvIGJhcnJhcXVlcm-SAQ5tZWRpY2FsX2NlbnRlcuABAA!16s%2Fg%2F11gd67h0hc?entry=ttu"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline"
      >
        Ver todas las reseñas en Google
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
      </a>
    </div>
  </div>
</section>
