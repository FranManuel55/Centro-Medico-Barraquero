---
import { siteConfig, getWhatsAppUrlContextual } from '../../data/siteConfig';

const contactItems = [
  {
    icon: 'pin',
    label: 'Ubicación',
    lines: [
      `${siteConfig.address.street}, ${siteConfig.address.city}`,
      `${siteConfig.address.province}, ${siteConfig.address.country}`,
    ],
  },
  {
    icon: 'whatsapp',
    label: 'WhatsApp',
    href: getWhatsAppUrlContextual('Hola! Me gustaría obtener más información.'),
    lines: [`+54 ${siteConfig.whatsapp.number}`],
  },
  {
    icon: 'mail',
    label: 'Email',
    href: `mailto:${siteConfig.email}`,
    lines: [siteConfig.email],
  },
  {
    icon: 'clock',
    label: 'Horarios',
    lines: ['Lun a Vie: 08:00 - 20:00', 'Sábados: 08:00 - 13:00', 'Domingos: cerrado'],
  },
];
---

<section id="contacto" class="section-padding bg-gray-50/60 relative overflow-hidden">
  <div
    class="absolute -bottom-32 right-0 w-96 h-96 bg-secondary/5 rounded-full blur-3xl pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="container-custom relative">
    <div class="text-center max-w-2xl mx-auto mb-14" data-reveal>
      <span class="eyebrow-accent mb-4">Contacto</span>
      <h2 class="section-title mb-4">Encontranos fácilmente</h2>
      <p class="section-lead">
        Estamos acá para ayudarte. Contactanos por WhatsApp, email o visitanos en nuestras
        instalaciones.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-8" data-reveal>
      <div class="lg:col-span-2">
        <div class="bg-white rounded-2xl shadow-sm ring-1 ring-gray-100 p-6 lg:p-8 h-full flex flex-col">
          <h3 class="text-xl font-serif font-semibold text-text mb-6">Información de contacto</h3>

          <div class="space-y-5 flex-1">
            {contactItems.map((item) => (
              <div class="flex items-start gap-4">
                <div class="w-11 h-11 bg-secondary/10 rounded-xl flex items-center justify-center shrink-0">
                  {item.icon === 'pin' && (
                    <svg class="w-5 h-5 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                    </svg>
                  )}
                  {item.icon === 'whatsapp' && (
                    <svg class="w-5 h-5 text-secondary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                  )}
                  {item.icon === 'mail' && (
                    <svg class="w-5 h-5 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                    </svg>
                  )}
                  {item.icon === 'clock' && (
                    <svg class="w-5 h-5 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  )}
                </div>
                <div class="min-w-0">
                  <p class="font-semibold text-text text-sm mb-1">{item.label}</p>
                  {item.href ? (
                    <a
                      href={item.href}
                      target={item.icon === 'whatsapp' ? '_blank' : undefined}
                      rel={item.icon === 'whatsapp' ? 'noopener noreferrer' : undefined}
                      class="text-accent hover:text-accent-dark transition-colors text-sm break-all"
                    >
                      {item.lines[0]}
                    </a>
                  ) : (
                    <div class="text-text-secondary text-sm space-y-0.5">
                      {item.lines.map((line) => (
                        <p>{line}</p>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 pt-6 border-t border-gray-100">
            <a
              href={getWhatsAppUrlContextual('Hola! Me gustaría consultar por un turno.')}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-secondary w-full justify-center"
            >
              <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Escribinos por WhatsApp
            </a>
          </div>
        </div>
      </div>

      <div class="lg:col-span-3">
        <div class="bg-white rounded-2xl shadow-sm ring-1 ring-gray-100 overflow-hidden h-full min-h-[420px]">
          <!-- PLACEHOLDER: Iframe de Google Maps -->
          <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-50 flex items-center justify-center relative">
            <div
              class="absolute inset-0 opacity-[0.04]"
              style="background-image: linear-gradient(0deg, rgb(0 0 0) 1px, transparent 1px), linear-gradient(90deg, rgb(0 0 0) 1px, transparent 1px); background-size: 32px 32px;"
              aria-hidden="true"
            ></div>
            <div class="text-center p-8 relative">
              <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-white shadow-md ring-1 ring-gray-100 flex items-center justify-center">
                <svg class="w-8 h-8 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                </svg>
              </div>
              <p class="text-text font-semibold mb-1">{siteConfig.name}</p>
              <p class="text-text-secondary text-sm mb-4">
                {siteConfig.address.street}, {siteConfig.address.city}
              </p>
              <a
                href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${siteConfig.address.street} ${siteConfig.address.city} ${siteConfig.address.province}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-accent hover:text-accent-dark text-sm font-semibold transition-colors"
              >
                Cómo llegar
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
