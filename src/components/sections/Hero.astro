---
import { siteConfig, getWhatsAppUrlContextual } from '../../data/siteConfig';
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center pt-20 md:pt-24 overflow-hidden"
>
  <div class="absolute inset-0 bg-gradient-to-br from-white via-primary to-secondary/5 -z-10"></div>

  <div
    class="absolute top-20 right-0 w-[600px] h-[600px] bg-secondary/10 rounded-full blur-3xl -z-10"
    aria-hidden="true"
  ></div>
  <div
    class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent/10 rounded-full blur-3xl -z-10"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-0 -z-10 opacity-[0.04]"
    style="background-image: radial-gradient(rgb(31 41 55) 1px, transparent 1px); background-size: 24px 24px;"
    aria-hidden="true"
  ></div>

  <div class="container-custom">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="animate-fade-in-up">
        <span class="eyebrow-secondary mb-6">Centro Médico Especializado</span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold text-text leading-[1.1] tracking-tight mb-6">
          Recuperá tu <span class="relative inline-block text-secondary">
            bienestar
            <svg
              class="absolute -bottom-1 left-0 w-full"
              viewBox="0 0 200 10"
              preserveAspectRatio="none"
              aria-hidden="true"
            >
              <path
                d="M2 7 Q 50 2, 100 5 T 198 4"
                stroke="currentColor"
                stroke-width="2.5"
                fill="none"
                stroke-linecap="round"
                opacity="0.4"
              />
            </svg>
          </span> con atención personalizada
        </h1>

        <p class="text-lg md:text-xl text-text-secondary mb-8 max-w-xl leading-relaxed">
          Kinesiología y rehabilitación física con profesionales altamente capacitados. Te ayudamos
          a recuperarte y mejorar tu calidad de vida.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={getWhatsAppUrlContextual('Hola! Me gustaría solicitar un turno en Centro Médico Barraquero.')}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary text-center"
          >
            <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Reservá tu turno
          </a>
          <a href="#servicios" class="btn-outline text-center">
            Conocé nuestros servicios
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
          </a>
        </div>

        <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-4">
          <div>
            <p class="text-3xl md:text-4xl font-serif font-semibold text-accent leading-none">+1.500</p>
            <p class="text-sm text-text-secondary mt-1.5">Pacientes atendidos</p>
          </div>
          <div class="w-px h-10 bg-gray-200" aria-hidden="true"></div>
          <div>
            <p class="text-3xl md:text-4xl font-serif font-semibold text-accent leading-none">+10</p>
            <p class="text-sm text-text-secondary mt-1.5">Años de experiencia</p>
          </div>
          <div class="w-px h-10 bg-gray-200" aria-hidden="true"></div>
          <div>
            <div class="flex items-center gap-1.5">
              <p class="text-3xl md:text-4xl font-serif font-semibold text-accent leading-none">{siteConfig.rating.average}</p>
              <svg class="w-5 h-5 text-yellow-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
            <p class="text-sm text-text-secondary mt-1.5">Rating en Google</p>
          </div>
        </div>
      </div>

      <div class="relative hidden lg:block">
        <div class="relative w-full aspect-square">
          <div
            class="absolute inset-0 bg-gradient-to-br from-secondary/20 to-accent/20 rounded-3xl transform rotate-3"
            aria-hidden="true"
          ></div>
          <div class="absolute inset-0 bg-white rounded-3xl shadow-2xl overflow-hidden ring-1 ring-gray-100">
            <!-- PLACEHOLDER: Imagen del centro médico -->
            <div class="w-full h-full bg-gradient-to-br from-secondary/40 via-secondary/30 to-accent/40 flex items-center justify-center">
              <div class="text-center p-8">
                <svg
                  class="w-24 h-24 text-white/80 mx-auto mb-4"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                </svg>
                <p class="text-white/90 text-sm font-semibold tracking-wide uppercase">Imagen del Centro Médico</p>
              </div>
            </div>
          </div>
        </div>

        <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl ring-1 ring-gray-100 p-4 animate-fade-in">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 bg-secondary/10 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-secondary" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-text">Turno disponible</p>
              <p class="text-xs text-text-secondary">Consultá ahora</p>
            </div>
          </div>
        </div>

        <div class="absolute -top-4 -right-4 bg-white rounded-2xl shadow-xl ring-1 ring-gray-100 p-4 animate-fade-in">
          <div class="flex items-center gap-3">
            <div class="flex -space-x-2">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-secondary to-secondary/70 ring-2 ring-white"></div>
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-accent to-accent-dark ring-2 ring-white"></div>
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-yellow-400 to-yellow-500 ring-2 ring-white flex items-center justify-center">
                <span class="text-[10px] font-bold text-white">+</span>
              </div>
            </div>
            <div>
              <div class="flex items-center gap-1">
                {[1, 2, 3, 4, 5].map(() => (
                  <svg class="w-3 h-3 text-yellow-400" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
              <p class="text-xs text-text-secondary mt-0.5">+{siteConfig.rating.count} reseñas</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
